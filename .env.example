# Copy to .env and adjust as needed

# ── API ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
API_LOG_LEVEL=debug

# ── Postgres ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://liquor:liquor@localhost:5435/liquor
POSTGRES_USER=liquor
POSTGRES_PASSWORD=liquor
POSTGRES_DB=liquor

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Object storage (MinIO local; S3 in prod) ────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=liquor
S3_SECRET_KEY=liquorliquor
S3_BUCKET=liquor-media

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-only-change-me-in-prod-please
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# In dev, OTP is always this value
DEV_OTP=123456
