    "dotenv": "16.4.5",
    "fastify": "5.1.0",
    "fastify-plugin": "5.0.1",
    "jose": "^6.2.2",
    "pino": "9.5.0",
    "pino-pretty": "11.3.0",
    "postgres": "3.4.5",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
