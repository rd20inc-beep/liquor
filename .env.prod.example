# Liquor OS — production environment template.
# Used by compose.prod.yml. Copy to .env on the target host and fill in.

POSTGRES_USER=liquor
POSTGRES_PASSWORD=
POSTGRES_DB=liquor

# S3-compatible (MinIO by default)
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=liquor-uploads

# Must be >=16 chars — generate with: openssl rand -hex 32
JWT_SECRET=

# Dev-only fixed OTP. Replace the /auth/login path with real SMS before opening to real users.
DEV_OTP=123456
